# MySQL settings (required)
DB_HOST=localhost
DB_PORT=3306
DB_USER=robotvacuum
DB_PASSWORD=robotvacuum
DB_NAME=robotvacuum

# 模型配置
MODEL_NAME=qwen3:8b
MODEL_NAME2=glm4:9b
BASE_URL=http://localhost:11434
EMBEDDING_NAME=bge-m3
TEMPERATURE=0.2

# 分词参数
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# 向量库检索
K=3
COLLECTION_NAME=agent
PERSIST_DIRECTORY_NAME=rag/chroma_db

# 路径配置
VECTOR_STORE_PATH=data
LOG_SAVE_FILE=backend/logs
MD5_FILE_PATH=md5.txt

# 长期记忆参数
LONG_TERM_SIMILARITY_THRESHOLD=0.7
LONG_TERM_MAX_MEMORIES=200
LONG_TERM_K_RETRIEVAL=3
# 长期记忆目录
LONG_TERM_MEMORY_DIR=rag/long_term_memory

# 评估数据集路径
EVALUATE_QUES2QUERY_PATH=evaluate/ques2query_dataset.json

# prompts 路径
AGENT_PROMPTS=prompts/agent_prompt.txt
SUMMARIZE_PROMPTS=prompts/rag_summarize_prompt.txt
REPAIR_PROMPTS=prompts/rag_repair_prompt.txt
MAINTAIN_PROMPTS=prompts/rag_maintain_prompt.txt
GUIDE_PROMPTS=prompts/rag_guide_prompt.txt
REPORT_PROMPTS=prompts/report_prompt.txt
QUERY_ROUTING_PROMPTS=prompts/rag_query_routing.txt
QUERY_REWRITING_PROMPTS=prompts/rag_query_rewriting.txt

# LLM API Keys（配置后才能在聊天页面下拉框中看到对应模型）
# 本地模型（无需 Key）：qwen3:8b / qwen2.5:7b / llama3.1:8b / glm4:9b
# 免费模型（需注册获取 API Key）：
# GEMINI_API_KEY=your_gemini_key_here
# GLM_API_KEY=your_glm_key_here
# QWEN_API_KEY=your_qwen_key_here
# DEEPSEEK_API_KEY=your_deepseek_key_here
# ARK_API_KEY=your_ark_key_here
# BAIDU_API_KEY=your_baidu_key_here
# HUNYUAN_API_KEY=your_hunyuan_key_here
# 付费模型（需注册获取 API Key）：
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# MOONSHOT_API_KEY=your_moonshot_key_here
# MISTRAL_API_KEY=your_mistral_key_here
# YI_API_KEY=your_yi_key_here
# MINIMAX_API_KEY=your_minimax_key_here
# BAICHUAN_API_KEY=your_baichuan_key_here
# XAI_API_KEY=your_xai_key_here
 
 # RL 导航配置
 USE_RL_NAVIGATION=false
 RL_MODEL_PATH=./rl_models/pure/final_robot_policy.zip
 RL_HYBRID_MODE=false
 
